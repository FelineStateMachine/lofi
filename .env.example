# Public deployment base. Blank defaults to an origin-root deployment (/); use
# /my-app/ when the static host mounts the build below the origin root.
LOFI_BASE_PATH=

# lofi's client-visible Jazz configuration. The runtime maps this complete pair
# to framework-prefixed vendor names internally; product UI never reads it.
JAZZ_APP_ID=
JAZZ_SERVER_URL=

# Server-only credentials. Never expose these through PUBLIC_ or client code.
JAZZ_ADMIN_SECRET=
BACKEND_SECRET=
