---
import AccountGate from "../islands/AccountGate";
import MagmaBackdrop from "../islands/MagmaBackdrop";
import TaskList from "../islands/TaskList";
import { DeviceStatus } from "@nzip/lofi/preact";
import Shell from "../layouts/Shell.astro";
import { app } from "../app.ts";
import "../styles/global.css";
---

<Shell title="lofi demo">
  <MagmaBackdrop client:idle />
  <header class="hero">
    <p class="eyebrow">lofi demo · <span class="badge">@nzip/lofi@__LOFI_DEMO_VERSION__</span></p>
    <h1>Hello, Molten World.</h1>
    <p>
      The starter task app, generated by the release workflow from the exact package version above
      and restyled to be everything the template is not. Same schema surface, same islands, same
      offline guarantees.
    </p>
    <div class="hero-links">
      <a class="hot" href="https://lofi.host/docs/getting-started">Build your own</a>
      <a href="https://lofi.host">lofi.host</a>
      <a href={app.repositoryUrl} rel="noreferrer">Source</a>
    </div>
  </header>
  <div class="demo-cards">
    <article class="card">
      <h3>Encrypted at rest</h3>
      <p>
        The tasks table is declared with <code>s.privateTable</code>: every column is sealed before
        it reaches storage, so what persists in this browser is ciphertext.
      </p>
    </article>
    <article class="card">
      <h3>Strict CSP</h3>
      <p>
        Each page carries a strict Content-Security-Policy, and this deployment mirrors it as a
        real response header. View source, or check the response headers.
      </p>
    </article>
    <article class="card">
      <h3>Bring your own sync</h3>
      <p>
        This build is compiled local-only: nothing leaves the device. Run your own
        <a href="https://lofi.host/node">lofi-node</a> and paste its <code>lofisync1.</code>
        app-connect ticket in the <a href="#account-title">account panel</a>; enrollment binds the
        ticket to this device.
      </p>
      <p class="card-note">
        Passkeys created here bind to demo.lofi.host. Treat this as a scratch playground.
      </p>
    </article>
  </div>
  <AccountGate client:load />
  <TaskList client:load />
  <DeviceStatus client:load />
  <footer>
    <a href={app.repositoryUrl} rel="noreferrer">lofi on GitHub →</a>
  </footer>
</Shell>
