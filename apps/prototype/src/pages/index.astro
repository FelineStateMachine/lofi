---
import NotesIsland from "../components/NotesIsland";
import DeviceStatus from "../components/DeviceStatus";
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="theme-color" content="#18231f" />
    <link rel="icon" href="./favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="./manifest.webmanifest" />
    <title>lofi prototype</title>
  </head>
  <body>
    <main>
      <header class="hero">
        <p class="eyebrow">M1 graduated candidate</p>
        <h1>One local-first runtime.<br />Two Astro islands.</h1>
        <p>
          Writes are local first, storage is explicit, and framework machinery stays behind the
          component boundary.
        </p>
      </header>
      <div class="island-grid">
        <NotesIsland label="North island" client:load />
        <NotesIsland label="South island" client:load />
      </div>
      <DeviceStatus client:load />
      <footer>Thin Preact adapter · static Astro shell · Deno command surface</footer>
    </main>
  </body>
</html>
