{
  "imports": {
    "@astrojs/check": "npm:@astrojs/check@0.9.9",
    "@astrojs/preact": "npm:@astrojs/preact@6.0.1",
    "@nzip/lofi": "jsr:@nzip/lofi@0.3.0",
    "@nzip/lofi/": "jsr:@nzip/lofi@0.3.0/",
    "@nzip/lofi/access": "jsr:@nzip/lofi@0.3.0/access",
    "@nzip/lofi/astro": "jsr:@nzip/lofi@0.3.0/astro",
    "@nzip/lofi/build": "jsr:@nzip/lofi@0.3.0/build",
    "@nzip/lofi/dev": "jsr:@nzip/lofi@0.3.0/dev",
    "@nzip/lofi/doctor": "jsr:@nzip/lofi@0.3.0/doctor",
    "@nzip/lofi/preview": "jsr:@nzip/lofi@0.3.0/preview",
    "@nzip/lofi/preact": "jsr:@nzip/lofi@0.3.0/preact",
    "@nzip/lofi/provision": "jsr:@nzip/lofi@0.3.0/provision",
    "@nzip/lofi/test": "jsr:@nzip/lofi@0.3.0/test",
    "@nzip/lofi/testing": "jsr:@nzip/lofi@0.3.0/testing",
    "astro": "npm:astro@7.0.9",
    "astro/config": "npm:astro@7.0.9/config",
    "jazz-tools": "npm:jazz-tools@2.0.0-alpha.53",
    "jazz-tools/dev/vite": "npm:jazz-tools@2.0.0-alpha.53/dev/vite",
    "jazz-tools/passkey-backup": "npm:jazz-tools@2.0.0-alpha.53/passkey-backup",
    "jazz-tools/passphrase": "npm:jazz-tools@2.0.0-alpha.53/passphrase",
    "preact": "npm:preact@10.29.7",
    "preact/hooks": "npm:preact@10.29.7/hooks",
    "preact/jsx-dev-runtime": "npm:preact@10.29.7/jsx-dev-runtime",
    "preact/jsx-runtime": "npm:preact@10.29.7/jsx-runtime",
    "preact-render-to-string": "npm:preact-render-to-string@6.7.0",
    "typescript": "npm:typescript@6.0.3",
    "vite": "npm:vite@8.0.1"
  },
  "links": ["../.."],
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "lib": ["deno.ns", "dom", "dom.iterable", "esnext"],
    "jsx": "react-jsx",
    "jsxImportSource": "preact"
  },
  "tasks": {
    "dev": "deno run -A @nzip/lofi/dev",
    "doctor": "deno run -A @nzip/lofi/doctor",
    "test": "deno run -A @nzip/lofi/test",
    "build": "deno run -A @nzip/lofi/build",
    "preview": "deno run -A @nzip/lofi/preview",
    "jazz:provision": "deno run -A @nzip/lofi/provision",
    "deploy": "deno task build && deno deploy --prod dist",
    "deploy:create": "deno task build && deno deploy create dist --source local --do-not-use-detected-build-config --runtime-mode static --static-dir . --region us",
    "schema:validate": "deno run -A npm:jazz-tools@2.0.0-alpha.53 validate",
    "schema:deploy": "deno run --env-file=.env -A npm:jazz-tools@2.0.0-alpha.53 deploy --migrations-dir src/migrations",
    "migrations:create": "deno run -A npm:jazz-tools@2.0.0-alpha.53 migrations create --migrations-dir src/migrations",
    "migrations:push": "deno run --env-file=.env -A npm:jazz-tools@2.0.0-alpha.53 migrations push --migrations-dir src/migrations"
  },
  "fmt": {
    "lineWidth": 100,
    "semiColons": true,
    "singleQuote": false
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  }
}
