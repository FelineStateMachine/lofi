---
import AccountGate from "../islands/AccountGate";
import TaskList from "../islands/TaskList";
import { DeviceStatus } from "@nzip/lofi/preact";
import Shell from "../layouts/Shell.astro";
import { app } from "../app.ts";
import "../styles/global.css";
---

<Shell title="lofi starter">
  <header class="hero">
    <p class="eyebrow">lofi</p>
    <h1>Hello, lo-fi World.</h1>
    <p>
      Local-first mobile PWA meta-framework — Jazz 2 CRDT sync, Preact islands, Astro shell, Deno
      toolchain.
    </p>
    <p>Opinionated Offline-first.</p>
  </header>
  <AccountGate client:load />
  <TaskList client:load />
  <DeviceStatus client:load />
  {
    app.repositoryUrl && (
      <footer>
        <a href={app.repositoryUrl} rel="noreferrer">Source repository →</a>
      </footer>
    )
  }
</Shell>
