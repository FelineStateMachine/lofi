---
import TaskList from "../islands/TaskList";
import DeviceStatus from "../_lofi/DeviceStatus";
import Shell from "../_lofi/Shell.astro";
import "../styles/global.css";
---

<Shell title="lofi starter">
  <header class="hero">
    <p class="eyebrow">lofi</p>
    <h1>Local-first, by default.</h1>
    <p>
      Add a task and it persists on this device immediately - the UI never waits on the network.
      This starter is one island over one table; replace it with your own schema and components.
    </p>
  </header>
  <TaskList client:load />
  <aside class="identity-note" aria-label="Identity and recovery">
    <strong>Your data is local-first.</strong> Writes persist on this device immediately and, when
    managed sync is configured, replicate to your account. Set <code>identity: "device-passkey"</code>
    in <code>src/app.ts</code> to make a portable passkey the account — the same key then syncs this
    data to your other devices. lofi runs no recovery service: the account lives where the key lives.
  </aside>
  <DeviceStatus client:load />
  <footer>Thin Preact adapter · static Astro shell · Deno command surface</footer>
</Shell>
