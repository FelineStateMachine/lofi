{
  "name": "@nzip/lofi",
  "version": "0.9.0",
  "license": "MIT",
  "description": "A local-first Deno PWA framework with durable local data, recoverable accounts, optional Jazz sync, mutations with sync-boundary effects, and private, direct-share, or group access templates.",
  "exports": {
    ".": "./package/runtime/mod.ts",
    "./astro": "./package/astro/mod.ts",
    "./access": "./package/access/mod.ts",
    "./build": "./package/commands/build.ts",
    "./create": "./package/create.ts",
    "./dev": "./package/commands/dev.ts",
    "./doctor": "./package/commands/doctor.ts",
    "./preview": "./package/commands/preview.ts",
    "./preact": "./package/preact/mod.ts",
    "./provision": "./package/commands/provision.ts",
    "./schema": "./package/schema/mod.ts",
    "./schema/store": "./package/schema/store.ts",
    "./recipes/file-handler": "./package/recipes/file-handler.ts",
    "./recipes/launch-handler": "./package/recipes/launch-handler.ts",
    "./recipes/protocol-handler": "./package/recipes/protocol-handler.ts",
    "./recipes/related-app-discovery": "./package/recipes/related-app-discovery.ts",
    "./recipes/scope-extension": "./package/recipes/scope-extension.ts",
    "./recipes/web-share": "./package/recipes/web-share.ts",
    "./recipes/window-controls-overlay": "./package/recipes/window-controls-overlay.ts",
    "./testing": "./package/testing/mod.ts",
    "./test": "./package/commands/run_tests.ts"
  },
  "imports": {
    "@astrojs/check": "npm:@astrojs/check@0.9.9",
    "@astrojs/preact": "npm:@astrojs/preact@6.0.1",
    "@noble/ciphers/chacha": "npm:@noble/ciphers@1.3.0/chacha",
    "@noble/curves/ed25519": "npm:@noble/curves@1.9.7/ed25519",
    "@noble/hashes/hkdf": "npm:@noble/hashes@1.8.0/hkdf",
    "@noble/hashes/sha2": "npm:@noble/hashes@1.8.0/sha2",
    "astro": "npm:astro@7.0.9",
    "astro/config": "npm:astro@7.0.9/config",
    "jazz-tools": "npm:jazz-tools@2.0.0-alpha.53",
    "jazz-tools/dev/vite": "npm:jazz-tools@2.0.0-alpha.53/dev/vite",
    "jazz-tools/passkey-backup": "npm:jazz-tools@2.0.0-alpha.53/passkey-backup",
    "jazz-tools/passphrase": "npm:jazz-tools@2.0.0-alpha.53/passphrase",
    "jazz-tools/testing": "npm:jazz-tools@2.0.0-alpha.53/testing",
    "playwright": "npm:playwright@1.61.1",
    "preact": "npm:preact@10.29.7",
    "preact/hooks": "npm:preact@10.29.7/hooks",
    "preact/jsx-dev-runtime": "npm:preact@10.29.7/jsx-dev-runtime",
    "preact/jsx-runtime": "npm:preact@10.29.7/jsx-runtime",
    "typescript": "npm:typescript@6.0.3",
    "vite": "npm:vite@8.1.4"
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "lib": [
      "deno.ns",
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "jsx": "react-jsx",
    "jsxImportSource": "preact"
  },
  "tasks": {
    "build": "deno task --cwd apps/reference build",
    "check": "deno fmt --check . && deno lint && deno task doc && deno task doc:closure && deno task docs:links && deno task test:unit && deno task test:access && deno task test:effects && deno task test:conformance && deno task test:scenario",
    "doc": "deno run --allow-run tools/doc_lint.ts",
    "doc:closure": "deno run --allow-run --allow-read tools/type_closure_lint.ts",
    "docs:links": "deno run --allow-read tools/docs_links.ts",
    "test:unit": "deno test --allow-env=LOFI_UPDATE_SNAPSHOT,CI --allow-net=127.0.0.1 --allow-read --allow-write=. --allow-run tools package/astro package/create_core_test.ts package/preact package/project_layout_doc_test.ts package/pwa_assets_test.ts package/recipes package/runtime package/schema/compat_test.ts package/schema/effects_test.ts package/schema/encrypted_test.ts package/schema/encrypted_types_test.ts package/schema/mod_test.ts package/schema/nested_test.ts package/schema/private_table_test.ts package/schema/shared_crypto_test.ts package/schema/shared_encrypted_test.ts package/testing package/tooling apps/reference/tests",
    "test:access": "deno test --allow-env --allow-net=127.0.0.1 --allow-read --allow-write --allow-run --allow-ffi package/access/*_test.ts",
    "test:effects": "deno test --allow-env --allow-net=127.0.0.1 --allow-read --allow-write --allow-run --allow-ffi package/effects_sync_test.ts",
    "test:conformance": "deno test --allow-env --allow-net=127.0.0.1 --allow-read --allow-write --allow-run --allow-ffi package/schema/merge_sync_test.ts && deno test --allow-env --allow-net=127.0.0.1 --allow-read --allow-write --allow-run --allow-ffi package/schema/migration_test.ts && deno test --allow-env --allow-net=127.0.0.1 --allow-read --allow-write --allow-run --allow-ffi package/schema/sliceable_test.ts && deno test --allow-env --allow-net=127.0.0.1 --allow-read --allow-write --allow-run --allow-ffi package/schema/nested_conformance_test.ts && deno test --allow-env --allow-net=127.0.0.1 --allow-read --allow-write --allow-run --allow-ffi package/schema/store_test.ts && deno test --allow-env --allow-net=127.0.0.1 --allow-read --allow-write --allow-run --allow-ffi package/schema/conformance_test.ts",
    "test:scenario": "deno test --allow-env --allow-sys --allow-net=127.0.0.1 --allow-read --allow-write --allow-run --allow-ffi package/scenario_sync_test.ts",
    "test:update:create": "LOFI_UPDATE_SNAPSHOT=1 deno test --allow-env=LOFI_UPDATE_SNAPSHOT --allow-read --allow-write=. --allow-run package/create_core_test.ts",
    "test": "deno task test:unit",
    "test:browser:install": "deno run -A npm:playwright@1.61.1 install chromium",
    "test:golden": "deno run -A tools/golden.ts --source local",
    "test:golden:registry": "deno run -A tools/golden.ts --source registry",
    "site:api": "deno run --allow-read --allow-run --allow-write=website/api-gen tools/api_docs.ts",
    "site:api:node": "deno run --allow-read --allow-run --allow-env=LOFI_NODE_DIR --allow-write=website/node-api-gen tools/api_docs.ts --node",
    "site:node": "deno run --allow-read --allow-run=git --allow-env=LOFI_NODE_DIR,LOFI_NODE_REF --allow-write=website/node-docs-gen tools/node_docs.ts",
    "site:llms": "deno run --allow-read --allow-write=website/static --allow-env=SITE_URL tools/site_llms.ts",
    "site:gen": "deno task site:api && deno task site:api:node && deno task site:node && deno task site:llms",
    "site:build": "deno task site:gen && npm run build --prefix website",
    "site:dev": "deno task site:gen && npm start --prefix website",
    "publish:dry": "deno publish --dry-run"
  },
  "fmt": {
    "lineWidth": 100,
    "semiColons": true,
    "singleQuote": false,
    "exclude": [
      "website",
      ".claude"
    ]
  },
  "lint": {
    "rules": {
      "tags": [
        "recommended"
      ]
    },
    "exclude": [
      "website",
      ".claude"
    ]
  },
  "publish": {
    "include": [
      "LICENSE",
      "README.md",
      "docs/README.md",
      "docs/assets/brand/lofi-github-banner.png",
      "docs/application-origin-migration.md",
      "docs/auth-identity.md",
      "docs/auth.md",
      "docs/decisions/group-creator-authority-alpha53.md",
      "docs/decisions/passkey-backup-alpha53.md",
      "docs/decisions/schema-facade-alpha53.md",
      "docs/data-and-ui.md",
      "docs/deployment.md",
      "docs/getting-started.md",
      "docs/nouns-and-verbs.md",
      "docs/examples",
      "docs/permissions.md",
      "docs/reference",
      "docs/recipes",
      "docs/store-provisioning.md",
      "docs/sync-and-recovery.md",
      "docs/testing.md",
      "docs/threat-model.md",
      "docs/troubleshooting.md",
      "apps/reference/deno.json",
      "apps/reference/public",
      "apps/reference/src",
      "apps/reference/tests",
      "apps/reference/tsconfig.json",
      "package"
    ],
    "exclude": [
      "package/**/*_test.ts",
      "package/**/*_test.tsx",
      "package/testing/fixture_integration.ts",
      "package/testdata"
    ]
  }
}
