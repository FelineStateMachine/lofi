{
  "$schema": "https://jsr.io/schema/config-file.v1.json",
  "name": "@nzip/lofi",
  "version": "0.1.0",
  "license": "MIT",
  "exports": {
    "./build": "./package/commands/build.ts",
    "./create": "./package/create.ts",
    "./dev": "./package/commands/dev.ts",
    "./doctor": "./package/commands/doctor.ts",
    "./preview": "./package/commands/preview.ts",
    "./testing": "./package/testing/mod.ts",
    "./test": "./package/commands/run_tests.ts"
  },
  "publish": {
    "include": [
      "LICENSE",
      "README.md",
      "apps/reference/astro.config.ts",
      "apps/reference/public",
      "apps/reference/src",
      "apps/reference/tests",
      "apps/reference/tsconfig.json",
      "package"
    ],
    "exclude": [
      "package/**/*_test.ts",
      "package/testing/fixture_integration.ts",
      "package/testdata"
    ]
  }
}
